{
  "env": {
    "node": true,
    "es2023": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2023
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-constant-condition": ["error", { "checkLoops": false }],
    "require-atomic-updates": "off"
  },
  "ignorePatterns": ["node_modules/", "target/", "*.yml", "*.jar"]
}
