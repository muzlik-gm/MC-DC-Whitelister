# Whitelist Bot — Global Configuration
# Only values that apply to ALL servers go here.
# Per-server config (MC host, port, API key) is stored per guild via /setup or /pair.

DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID_HERE

# Optional: Tunnel server port (default: 9000)
# TUNNEL_PORT=9000

# Optional: Node environment (production/development)
# NODE_ENV=production

# Optional: API key for direct HTTP mode (used as fallback when no guild config exists)
# MINECRAFT_API_KEY=
